<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".MainActivity">

    <!-- Titolo dell'app -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Speech Command Spotting"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="20dp"
        android:textColor="@android:color/black" />

    <!-- Pulsante di registrazione -->
    <Button
        android:id="@+id/btnRecord"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="START RECORDING"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"
        android:background="@drawable/button_background"
        android:textColor="@android:color/white" />

    <!-- Informazioni sui comandi vocali -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Comandi vocali riconosciuti (10):"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="stop, down, off, right, up, go, on, yes, left, no"
        android:textSize="14sp"
        android:layout_marginBottom="20dp"
        android:textColor="@android:color/holo_blue_dark"
        android:textStyle="italic" />

    <!-- Titolo del log -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Log Eventi:"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <!-- Area di log con scroll -->
    <ScrollView
        android:id="@+id/scrollViewLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/log_background"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="@android:color/black"
            android:text="Avvio dell'applicazione...\n" />

    </ScrollView>

    <!-- Informazioni aggiuntive -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Frequenza campionamento: 16kHz"
            android:textSize="10sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginEnd="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TensorFlow Lite"
            android:textSize="10sp"
            android:textColor="@android:color/darker_gray" />

    </LinearLayout>

</LinearLayout>